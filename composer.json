{
    "name": "10quality/wpmvc",
    "type": "project",
    "description": "WordPress MVC Framework.",
    "keywords": [
        "framework",
        "wpmvc",
        "wordpress",
        "mvc"
    ],
    "license": "MIT",
    "require": {
        "php": ">=5.4.0",
        "10quality/wpmvc-addon-administrator": "^1.0",
        "10quality/wpmvc-addon-metaboxer": "^1.0",
        "10quality/wpmvc-addon-status": "1.0",
        "10quality/wpmvc-core": "^3.1",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "10quality/wpmvc-commands": "1.1.*",
        "phpunit/phpunit": "9.*",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "config": {
        "autoloader-suffix": "N8nMarketingTrigger",
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "N8nMarketingTrigger\\": "app"
        },
        "files": [
            "app/Globals/functions.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
